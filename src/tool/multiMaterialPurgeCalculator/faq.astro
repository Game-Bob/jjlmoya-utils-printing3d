---
import { FAQSection } from '@jjlmoya/utils-shared';
import { multiMaterialPurgeCalculator } from './index';
import type { KnownLocale } from '../../types';

interface Props {
  locale?: KnownLocale;
}

const { locale = 'en' } = Astro.props;
const content = await multiMaterialPurgeCalculator.i18n[locale]?.();
---

{content?.faq?.length > 0 && <FAQSection items={content.faq} />}
