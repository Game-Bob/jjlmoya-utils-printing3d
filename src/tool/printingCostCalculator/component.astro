---
import type { PrintingCostCalculatorUI } from './ui';

interface Props {
  ui: PrintingCostCalculatorUI;
}

const { ui } = Astro.props;
---

<div class="pcc-root">
  <div class="calculator-grid">
    <div class="control-panel">
      <div class="section-card">
        <h3>{ui.materialTitle}</h3>
        <div class="control-group">
          <label>{ui.partWeightLabel}</label>
          <div class="input-container">
            <input type="number" id="part-weight" value="150" min="1" />
            <span class="unit-tag">{ui.gramsUnit}</span>
          </div>
        </div>
        <div class="control-group">
          <label>{ui.spoolPriceLabel}</label>
          <div class="input-container">
            <input type="number" id="spool-price" value="25" step="0.5" min="1" />
            <span class="unit-tag">{ui.spoolPriceUnit}</span>
          </div>
        </div>
        <div class="control-group">
          <label>{ui.wasteMarginLabel} <span id="waste-display">5</span>%</label>
          <input type="range" id="waste-margin" min="0" max="30" value="5" class="range-control" />
        </div>
      </div>

      <div class="section-card">
        <h3>{ui.energyTitle}</h3>
        <div class="control-group">
          <label>{ui.printTimeLabel}</label>
          <div class="input-container">
            <input type="number" id="print-hours" value="10" min="0" />
            <span class="unit-tag">{ui.hoursUnit}</span>
          </div>
        </div>
        <div class="control-group">
          <label>{ui.averagePowerLabel}</label>
          <div class="input-container">
            <input type="number" id="power-watts" value="120" min="10" />
            <span class="unit-tag">{ui.wattsUnit}</span>
          </div>
        </div>
        <div class="control-group">
          <label>{ui.electricityRateLabel}</label>
          <div class="input-container">
            <input type="number" id="kwh-price" value="0.18" step="0.01" min="0.01" />
            <span class="unit-tag">{ui.kwhPriceUnit}</span>
          </div>
        </div>
      </div>

      <div class="section-card">
        <h3>{ui.amortizationTitle}</h3>
        <div class="control-group">
          <label>{ui.machineCostHourLabel}</label>
          <div class="input-container">
            <input type="number" id="machine-cost-hour" value="0.10" step="0.05" min="0" />
            <span class="unit-tag">{ui.priceHourUnit}</span>
          </div>
        </div>
        <div class="control-group">
          <label>{ui.laborCostHourLabel}</label>
          <div class="input-container">
            <input type="number" id="labor-cost-hour" value="15" step="1" min="0" />
            <span class="unit-tag">{ui.priceHourUnit}</span>
          </div>
          <div class="input-container" style="margin-top: 0.5rem">
            <input type="number" id="labor-minutes" value="20" min="0" />
            <span class="unit-tag">{ui.minutesUnit}</span>
          </div>
        </div>
      </div>
    </div>

    <div class="results-panel">
      <div class="total-card">
        <span class="total-label">{ui.manufacturingCostLabel}</span>
        <div class="total-value">
          <span id="total-cost">0.00</span>€
        </div>

        <div class="suggested-price">
          <span class="suggested-label" id="suggested-label-tmpl">{ui.suggestedPriceLabel}</span>
          <div class="suggested-value">
            <span id="suggested-price">0.00</span>€
          </div>
          <input type="range" id="profit-margin" min="0" max="300" value="50" class="range-control" />
        </div>
      </div>

      <div class="breakdown-chart">
        <h4 class="chart-title">{ui.costBreakdownTitle}</h4>
        <div class="bars-container">
          <div class="bar-row">
            <div class="bar-label"><span>{ui.plasticLabel}</span> <span id="perc-material">0%</span></div>
            <div class="bar-wrapper"><div id="bar-material" class="bar-fill bar-material"></div></div>
          </div>
          <div class="bar-row">
            <div class="bar-label"><span>{ui.electricityLabel}</span> <span id="perc-energy">0%</span></div>
            <div class="bar-wrapper"><div id="bar-energy" class="bar-fill bar-energy"></div></div>
          </div>
          <div class="bar-row">
            <div class="bar-label"><span>{ui.machineLabel}</span> <span id="perc-machine">0%</span></div>
            <div class="bar-wrapper"><div id="bar-machine" class="bar-fill bar-machine"></div></div>
          </div>
          <div class="bar-row">
            <div class="bar-label"><span>{ui.laborLabel}</span> <span id="perc-labor">0%</span></div>
            <div class="bar-wrapper"><div id="bar-labor" class="bar-fill bar-labor"></div></div>
          </div>
        </div>
      </div>

      <div class="pro-tip">
        {ui.proTip}
      </div>
    </div>
  </div>
</div>

<script>
  import { calculatePrintingCost } from './logic';
  import type { PrintingCostResult } from './logic';

  class PrintingCalculator {
    private inputs!: {
      weight: HTMLInputElement;
      spoolPrice: HTMLInputElement;
      waste: HTMLInputElement;
      hours: HTMLInputElement;
      watts: HTMLInputElement;
      kwh: HTMLInputElement;
      machine: HTMLInputElement;
      laborRate: HTMLInputElement;
      laborMin: HTMLInputElement;
      margin: HTMLInputElement;
    };
    private displays!: {
      total: HTMLElement;
      suggested: HTMLElement;
      wasteVal: HTMLElement;
      marginVal: HTMLElement;
      suggestedLabel: HTMLElement;
      pMat: HTMLElement;
      pEng: HTMLElement;
      pMac: HTMLElement;
      pLab: HTMLElement;
    };
    private bars!: {
      mat: HTMLElement;
      eng: HTMLElement;
      mac: HTMLElement;
      lab: HTMLElement;
    };
    private suggestedLabelTemplate = '';

    constructor() {
      this.initElements();
      this.initEvents();
    }

    private initElements() {
      this.initInputs();
      this.initDisplays();
      this.initBars();
      this.suggestedLabelTemplate = this.displays.suggestedLabel?.textContent || '';
    }

    private initInputs() {
      this.inputs = {
        weight: document.getElementById('part-weight') as HTMLInputElement,
        spoolPrice: document.getElementById('spool-price') as HTMLInputElement,
        waste: document.getElementById('waste-margin') as HTMLInputElement,
        hours: document.getElementById('print-hours') as HTMLInputElement,
        watts: document.getElementById('power-watts') as HTMLInputElement,
        kwh: document.getElementById('kwh-price') as HTMLInputElement,
        machine: document.getElementById('machine-cost-hour') as HTMLInputElement,
        laborRate: document.getElementById('labor-cost-hour') as HTMLInputElement,
        laborMin: document.getElementById('labor-minutes') as HTMLInputElement,
        margin: document.getElementById('profit-margin') as HTMLInputElement,
      };
    }

    private initDisplays() {
      this.displays = {
        total: document.getElementById('total-cost') as HTMLElement,
        suggested: document.getElementById('suggested-price') as HTMLElement,
        wasteVal: document.getElementById('waste-display') as HTMLElement,
        marginVal: document.getElementById('margin-display') as HTMLElement,
        suggestedLabel: document.getElementById('suggested-label-tmpl') as HTMLElement,
        pMat: document.getElementById('perc-material') as HTMLElement,
        pEng: document.getElementById('perc-energy') as HTMLElement,
        pMac: document.getElementById('perc-machine') as HTMLElement,
        pLab: document.getElementById('perc-labor') as HTMLElement,
      };
    }

    private initBars() {
      this.bars = {
        mat: document.getElementById('bar-material') as HTMLElement,
        eng: document.getElementById('bar-energy') as HTMLElement,
        mac: document.getElementById('bar-machine') as HTMLElement,
        lab: document.getElementById('bar-labor') as HTMLElement,
      };
    }

    private initEvents() {
      if (!this.inputs.weight) return;
      Object.values(this.inputs).forEach((input) => {
        input.addEventListener('input', () => this.calculate());
      });
      this.calculate();
    }

    private gatherTechnicalInput() {
      return {
        weight: parseFloat(this.inputs.weight.value) || 0,
        waste: parseFloat(this.inputs.waste.value) || 0,
        hours: parseFloat(this.inputs.hours.value) || 0,
        watts: parseFloat(this.inputs.watts.value) || 0,
      };
    }

    private gatherEconomicInput() {
      return {
        spoolPrice: parseFloat(this.inputs.spoolPrice.value) || 0,
        kwh: parseFloat(this.inputs.kwh.value) || 0,
        machineRate: parseFloat(this.inputs.machine.value) || 0,
        laborRate: parseFloat(this.inputs.laborRate.value) || 0,
        laborMin: parseFloat(this.inputs.laborMin.value) || 0,
        margin: parseFloat(this.inputs.margin.value) || 0,
      };
    }

    private gatherInput() {
      return {
        ...this.gatherTechnicalInput(),
        ...this.gatherEconomicInput(),
      };
    }

    private calculate() {
      const p = this.gatherInput();
      const result = calculatePrintingCost(p);
      this.updateDisplays(result, p.waste, p.margin);
      this.updateChart(result);
    }

    private updateDisplays(res: PrintingCostResult, waste: number, margin: number) {
      if (this.displays.wasteVal) this.displays.wasteVal.textContent = waste.toString();
      if (this.displays.suggestedLabel) {
        this.displays.suggestedLabel.textContent = this.suggestedLabelTemplate.replace('{margin}', margin.toString());
      }
      if (this.displays.total) this.displays.total.textContent = res.total.toFixed(2);
      if (this.displays.suggested) this.displays.suggested.textContent = res.suggested.toFixed(2);
    }

    private updateChart(res: PrintingCostResult) {
      const { material, energy, machine, labor, total } = res;
      if (total <= 0) return;

      const stats = [
        { val: material, disp: this.displays.pMat, bar: this.bars.mat },
        { val: energy, disp: this.displays.pEng, bar: this.bars.eng },
        { val: machine, disp: this.displays.pMac, bar: this.bars.mac },
        { val: labor, disp: this.displays.pLab, bar: this.bars.lab },
      ];

      stats.forEach((s) => {
        const perc = (s.val / total) * 100;
        if (s.disp) s.disp.textContent = `${perc.toFixed(0)}%`;
        if (s.bar) s.bar.style.width = `${perc}%`;
      });
    }
  }

  const initPcc = () => {
    new PrintingCalculator();
  };

  document.addEventListener('astro:page-load', initPcc);
  initPcc();
</script>

<style>
  .pcc-root {
    --pc-primary: #f97316;
    --pc-primary-soft: rgba(249, 115, 22, 0.1);
    --pc-bg: #fff;
    --pc-card-bg: #f8fafc;
    --pc-border: #e2e8f0;
    --pc-text-main: #1e293b;
    --pc-text-muted: #64748b;
    --pc-text-light: #94a3b8;
    --pc-success: #16a34a;
    --pc-energy: #eab308;
    --pc-machine: #8b5cf6;
    --pc-labor: #06b6d4;
    --pc-gradient-start: #fffcf9;
    --pc-gradient-end: #fff7ed;
    --pc-tip-bg: #fff7ed;
    --pc-tip-text: #9a3412;
    --pc-shadow: rgba(0, 0, 0, 0.05);

    padding: 2.5rem;
    background: var(--pc-bg);
    border: 1px solid var(--pc-border);
    border-radius: 2.5rem;
    box-shadow: 0 20px 50px -10px var(--pc-shadow);
    max-width: 1000px;
    margin: 0 auto;
  }

  :global(.theme-dark) .pcc-root {
    --pc-bg: rgba(15, 23, 42, 0.6);
    --pc-card-bg: rgba(255, 255, 255, 0.03);
    --pc-border: rgba(255, 255, 255, 0.1);
    --pc-text-main: #f1f5f9;
    --pc-text-muted: #94a3b8;
    --pc-text-light: #64748b;
    --pc-gradient-start: #1e293b;
    --pc-gradient-end: #0f172a;
    --pc-tip-bg: #1c1917;
    --pc-tip-text: #fdba74;
    --pc-shadow: rgba(0, 0, 0, 0.3);
    
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .calculator-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3.5rem;
  }

  @media (max-width: 950px) {
    .calculator-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }

  .control-panel {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .section-card {
    background: var(--pc-card-bg);
    padding: 2rem;
    border-radius: 2rem;
    border: 1px solid var(--pc-border);
  }

  .section-card h3 {
    font-size: 0.85rem;
    font-weight: 800;
    color: var(--pc-primary);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .control-group {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .control-group label {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--pc-text-muted);
    display: flex;
    justify-content: space-between;
  }

  .input-container {
    position: relative;
    display: flex;
    align-items: center;
  }

  .input-container input {
    width: 100%;
    background: var(--pc-bg);
    border: 2px solid var(--pc-border);
    color: var(--pc-text-main);
    padding: 0.85rem 1.25rem;
    border-radius: 1rem;
    font-size: 1.15rem;
    font-weight: 700;
    outline: none;
    transition: all 0.2s ease;
  }

  .input-container input:focus {
    border-color: var(--pc-primary);
    box-shadow: 0 0 0 4px var(--pc-primary-soft);
  }

  .input-container .unit-tag {
    position: absolute;
    right: 1.25rem;
    font-size: 0.75rem;
    font-weight: 800;
    color: var(--pc-text-light);
    text-transform: uppercase;
  }

  .range-control {
    width: 100%;
    accent-color: var(--pc-primary);
    height: 6px;
    background: var(--pc-border);
    border-radius: 10px;
    cursor: pointer;
  }

  .results-panel {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .total-card {
    background: linear-gradient(135deg, var(--pc-gradient-start), var(--pc-gradient-end));
    padding: 3.5rem 2rem;
    border-radius: 2.5rem;
    border: 1px solid var(--pc-border);
    text-align: center;
    box-shadow: 0 15px 30px -5px var(--pc-primary-soft);
  }

  .total-label {
    font-size: 0.9rem;
    font-weight: 800;
    color: var(--pc-primary);
    text-transform: uppercase;
    letter-spacing: 0.25em;
    margin-bottom: 1.5rem;
    display: block;
  }

  .total-value {
    font-size: 5.5rem;
    font-weight: 900;
    color: var(--pc-text-main);
    line-height: 0.9;
    letter-spacing: -0.05em;
  }

  .suggested-price {
    margin-top: 2.5rem;
    padding-top: 2.5rem;
    border-top: 2px dashed var(--pc-border);
  }

  .suggested-label {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--pc-text-muted);
    margin-bottom: 0.5rem;
    display: block;
  }

  .suggested-value {
    font-size: 3rem;
    font-weight: 900;
    color: var(--pc-success);
    display: block;
    margin-bottom: 1.5rem;
  }

  .breakdown-chart {
    background: var(--pc-card-bg);
    padding: 2.5rem;
    border-radius: 2rem;
    border: 1px solid var(--pc-border);
  }

  .chart-title {
    font-size: 0.8rem;
    font-weight: 900;
    color: var(--pc-text-light);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 2rem;
    text-align: center;
  }

  .bars-container {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .bar-row {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .bar-label {
    display: flex;
    justify-content: space-between;
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--pc-text-muted);
  }

  .bar-wrapper {
    height: 14px;
    background: var(--pc-border);
    border-radius: 8px;
    overflow: hidden;
  }

  .bar-fill {
    height: 100%;
    transition: width 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .bar-material {
    background: var(--pc-primary);
    box-shadow: 0 0 15px var(--pc-primary-soft);
  }

  .bar-energy {
    background: var(--pc-energy);
    box-shadow: 0 0 15px rgba(234, 179, 8, 0.3);
  }

  .bar-machine {
    background: var(--pc-machine);
    box-shadow: 0 0 15px rgba(139, 92, 246, 0.3);
  }

  .bar-labor {
    background: var(--pc-labor);
    box-shadow: 0 0 15px rgba(6, 182, 212, 0.3);
  }

  .pro-tip {
    padding: 1.5rem;
    background: var(--pc-tip-bg);
    border-left: 6px solid var(--pc-primary);
    border-radius: 1rem;
    font-size: 0.95rem;
    color: var(--pc-tip-text);
    line-height: 1.6;
    font-weight: 500;
  }
</style>
