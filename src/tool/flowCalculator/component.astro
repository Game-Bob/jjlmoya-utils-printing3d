---
import { Icon } from "astro-icon/components";

interface Props {
  ui?: Record<string, unknown>;
}

const { ui } = Astro.props;
const t = (ui ?? {}) as Record<string, string>;
---

<div class="vf-root" id="main-tool">
    <header class="vf-tool-header">
        <h2>{t.title || "Calculadora de Caudal 3D"}</h2>
        <div class="vf-toggle-simple active" id="auto-link">
            <span>{t.autoAdjust || "AJUSTE AUTO 120%"}</span>
            <div class="vf-toggle-box"><div class="vf-toggle-knob"></div></div>
        </div>
    </header>

    <div class="vf-main-container">
        <aside class="vf-sidebar">
            <div class="vf-subsection">
                <div class="vf-subsection-title"><Icon name="mdi:settings" /> {t.configLabel || "CONFIGURACIÓN"}</div>

                <div class="vf-control-item">
                    <div class="vf-control-label-row">
                        <label>{t.nozzleLabel || "BOQUILLA"}</label>
                        <span class="vf-control-value" id="nozzle-v">0.40 mm</span>
                    </div>
                    <input type="range" class="vf-flat-range" id="nozzle-in" min="0.1" max="1.2" step="0.05" value="0.4" />
                </div>

                <div class="vf-control-item">
                    <div class="vf-control-label-row">
                        <label>{t.lineWidthLabel || "ANCHO LÍNEA"}</label>
                        <span class="vf-control-value" id="width-v">0.48 mm</span>
                    </div>
                    <input type="range" class="vf-flat-range" id="width-in" min="0.1" max="1.8" step="0.01" value="0.48" disabled />
                </div>

                <div class="vf-control-item">
                    <div class="vf-control-label-row">
                        <label>{t.layerHeightLabel || "ALTURA CAPA"}</label>
                        <span class="vf-control-value" id="layer-v">0.20 mm</span>
                    </div>
                    <input type="range" class="vf-flat-range" id="layer-in" min="0.05" max="1.0" step="0.01" value="0.2" />
                </div>

                <div class="vf-control-item">
                    <div class="vf-control-label-row">
                        <label>{t.speedLabel || "VELOCIDAD"}</label>
                        <span class="vf-control-value" id="speed-v">60 mm/s</span>
                    </div>
                    <input type="range" class="vf-flat-range" id="speed-in" min="10" max="600" step="5" value="60" />
                </div>

                <div class="vf-control-item">
                    <div class="vf-control-label-row">
                        <label>{t.temperatureLabel || "TEMPERATURA"}</label>
                        <span class="vf-control-value" id="temp-v">210 °C</span>
                    </div>
                    <input type="range" class="vf-flat-range" id="temp-in" min="180" max="320" step="5" value="210" />
                </div>
            </div>

            <div class="vf-subsection">
                <div class="vf-subsection-title"><Icon name="mdi:flask" /> {t.materialLabel || "MATERIAL"}</div>
                <div class="vf-material-grid" id="mat-chips">
                    <button class="vf-chip-select active" data-mod="1.0" data-name="PLA">PLA</button>
                    <button class="vf-chip-select" data-mod="0.85" data-name="PETG">PETG</button>
                    <button class="vf-chip-select" data-mod="0.95" data-name="ABS">ABS/ASA</button>
                    <button class="vf-chip-select" data-mod="0.70" data-name="TPU">TPU/FLEX</button>
                </div>
            </div>

            <div class="vf-subsection">
                <div class="vf-subsection-title">
                    <Icon name="mdi:hot-tub" /> {t.hotendLimitLabel || "LÍMITE HOTEND"}
                    <span class="vf-tooltip-trigger" data-tooltip={t.hotendTooltip || "Capacidad base de fundido del hardware sin considerar material ni temperatura."}><Icon name="mdi:information-outline" /></span>
                </div>
                <div class="vf-preset-list">
                    <button class="vf-flat-button active" data-flow="10" data-tooltip={t.presetEnder || "Estándar MK8/V6. Zona de fundido corta."}>Ender-3 (10)</button>
                    <button class="vf-flat-button" data-flow="22" data-tooltip={t.presetBambu || "Hotend cerámico de alta velocidad."}>Bambu (22)</button>
                    <button class="vf-flat-button" data-flow="35" data-tooltip={t.presetVolcano || "Zona de fundido extra larga de 21mm."}>Volcano (35)</button>
                    <button class="vf-flat-button" data-flow="50" data-tooltip={t.presetHF || "Extrusores custom de altísimo rendimiento."}>HF Pro (50)</button>
                </div>
                <div class="vf-control-item" style="margin-top: 1.5rem;">
                    <div class="vf-control-label-row">
                        <label>{t.baseLimitLabel || "LÍMITE BASE"}</label>
                        <span class="vf-control-value" id="limit-v">10.0 mm³/s</span>
                    </div>
                    <input type="range" class="vf-flat-range" id="limit-in" min="1" max="100" step="0.5" value="10" />
                </div>
            </div>

            <div class="vf-reset-row">
                <button class="vf-btn-outline" id="reset-btn">{t.resetButton || "Restablecer valores"}</button>
            </div>
        </aside>

        <div class="vf-content-area">
            <div class="vf-hero-display" id="flow-panel">
                <div class="vf-hero-label">{t.volumetricFlowLabel || "CAUDAL VOLUMÉTRICO REAL"}</div>
                <div class="vf-hero-value" id="val-flow">5.76</div>
                <div class="vf-hero-unit">MM³/S</div>
                <div class="vf-limit-indicator">
                    <div class="vf-limit-fill" id="fill-flow"></div>
                </div>
            </div>

            <div class="vf-stats-grid">
                <div class="vf-stat-box" id="speed-panel">
                    <div class="vf-stat-label-box">{t.maxSpeedLabel || "VELOCIDAD MÁXIMA"}</div>
                    <div class="vf-stat-value-box" id="val-max-s">125 mm/s</div>
                </div>
                <div class="vf-stat-box" id="status-panel">
                    <div class="vf-stat-label-box">{t.statusLabel || "ESTADO"}</div>
                    <div class="vf-stat-value-box" id="val-status">{t.safeStatus || "SEGURO"}</div>
                </div>
            </div>

            <div class="vf-subsection" style="margin-bottom: 0;">
                <div class="vf-subsection-title"><Icon name="mdi:chart-areaspline" /> {t.stratifiedLabel || "RENDIMIENTO ESTRATIFICADO"}</div>
                <div class="vf-chart-area-flat" id="chart-area">
                    <svg viewBox="0 0 400 200" preserveAspectRatio="none" style="width: 100%; height: 100%; overflow: visible;" id="svg-c">
                        <line x1="0" y1="40" x2="400" y2="40" stroke="var(--vf-border)" stroke-width="1" />
                        <line x1="0" y1="80" x2="400" y2="80" stroke="var(--vf-border)" stroke-width="1" />
                        <line x1="0" y1="120" x2="400" y2="120" stroke="var(--vf-border)" stroke-width="1" />
                        <line x1="0" y1="160" x2="400" y2="160" stroke="var(--vf-border)" stroke-width="1" />

                        <line x1="80" y1="0" x2="80" y2="200" stroke="var(--vf-border)" stroke-width="1" />
                        <line x1="160" y1="0" x2="160" y2="200" stroke="var(--vf-border)" stroke-width="1" />
                        <line x1="240" y1="0" x2="240" y2="200" stroke="var(--vf-border)" stroke-width="1" />
                        <line x1="320" y1="0" x2="320" y2="200" stroke="var(--vf-border)" stroke-width="1" />

                        <path id="svg-p" fill="hsla(195, 100%, 50%, 0.1)" stroke="var(--vf-secondary)" stroke-width="3" d="" />
                        <circle id="svg-m-c" r="7" fill="var(--vf-text)" stroke="var(--vf-accent)" stroke-width="3" cx="0" cy="0" />

                        <text x="0" y="215" class="vf-axis-label" id="label-x-start">0.05</text>
                        <text x="380" y="215" class="vf-axis-label" id="label-x-end">1.00</text>
                        <text x="-35" y="10" class="vf-axis-label" style="text-anchor: end;">600</text>
                        <text x="-35" y="200" class="vf-axis-label" style="text-anchor: end;">0</text>
                    </svg>
                </div>
                <div style="display: flex; justify-content: space-between; font-size: 0.65rem; color: var(--vf-text-muted); padding-top: 1.5rem; font-weight: 700;">
                    <span>{t.chartHeightLabel || "ALTURA CAPA (MM)"}</span>
                    <span>{t.chartSpeedLabel || "LÍMITE VELOCIDAD (MM/S)"}</span>
                    <span>{t.chartSafeLabel || "GAMA SEGURA"}</span>
                </div>
            </div>
        </div>
    </div>

    <button class="vf-copy-action" id="copy-v">
        <Icon name="mdi:content-copy" />
        {t.copyButton || "COPIAR LÍMITE EFECTIVO"}
    </button>
</div>

<script>
    class AdvancedFlowAgent {
        nI: HTMLInputElement; wI: HTMLInputElement; lI: HTMLInputElement; sI: HTMLInputElement; limI: HTMLInputElement; tI: HTMLInputElement;
        nv: HTMLElement; wv: HTMLElement; lv: HTMLElement; sv: HTMLElement; limv: HTMLElement; tv: HTMLElement;
        fV: HTMLElement; sV: HTMLElement; stV: HTMLElement; fiF: HTMLElement;
        sP: SVGPathElement; sMC: SVGCircleElement;
        fP: HTMLElement; sPn: HTMLElement; stPn: HTMLElement;

        isAuto = true;
        matMod = 1.0;

        constructor() {
            this.nI = document.getElementById('nozzle-in') as HTMLInputElement;
            this.wI = document.getElementById('width-in') as HTMLInputElement;
            this.lI = document.getElementById('layer-in') as HTMLInputElement;
            this.sI = document.getElementById('speed-in') as HTMLInputElement;
            this.limI = document.getElementById('limit-in') as HTMLInputElement;
            this.tI = document.getElementById('temp-in') as HTMLInputElement;

            this.nv = document.getElementById('nozzle-v')!;
            this.wv = document.getElementById('width-v')!;
            this.lv = document.getElementById('layer-v')!;
            this.sv = document.getElementById('speed-v')!;
            this.limv = document.getElementById('limit-v')!;
            this.tv = document.getElementById('temp-v')!;

            this.fV = document.getElementById('val-flow')!;
            this.sV = document.getElementById('val-max-s')!;
            this.stV = document.getElementById('val-status')!;
            this.fiF = document.getElementById('fill-flow')!;

            this.sP = document.getElementById('svg-p') as unknown as SVGPathElement;
            this.sMC = document.getElementById('svg-m-c') as unknown as SVGCircleElement;
            this.fP = document.getElementById('flow-panel')!;
            this.sPn = document.getElementById('speed-panel')!;
            this.stPn = document.getElementById('status-panel')!;

            this.init();
        }

        setupInputListeners() {
            const upd = () => this.run();
            const inputs = [this.nI, this.wI, this.lI, this.sI, this.limI, this.tI];
            inputs.forEach(i => i.addEventListener('input', upd));
        }

        setupAutoToggle() {
            document.getElementById('auto-link')?.addEventListener('click', (e) => {
                const el = e.currentTarget as HTMLElement;
                this.isAuto = !this.isAuto;
                el.classList.toggle('vf-active', this.isAuto);
                this.wI.disabled = this.isAuto;
                this.run();
            });
        }

        setupMaterialButtons() {
            document.querySelectorAll('.vf-chip-select').forEach(c => {
                c.addEventListener('click', () => {
                    document.querySelectorAll('.vf-chip-select').forEach(x => x.classList.remove('vf-active'));
                    c.classList.add('vf-active');
                    this.matMod = parseFloat(c.getAttribute('data-mod')!);
                    this.run();
                });
            });
        }

        setupPresetButtons() {
            document.querySelectorAll('.vf-flat-button').forEach(b => {
                b.addEventListener('click', () => {
                    document.querySelectorAll('.vf-flat-button').forEach(x => x.classList.remove('vf-active'));
                    b.classList.add('vf-active');
                    this.limI.value = b.getAttribute('data-flow')!;
                    this.run();
                });
            });
        }

        setupResetButton() {
            document.getElementById('reset-btn')?.addEventListener('click', () => {
                this.nI.value = "0.4";
                this.lI.value = "0.2";
                this.sI.value = "60";
                this.tI.value = "210";
                if (!this.isAuto) document.getElementById('auto-link')?.click();
                this.run();
            });
        }

        setupCopyButton() {
            document.getElementById('copy-v')?.addEventListener('click', () => {
                const base = parseFloat(this.limI.value);
                const temp = parseInt(this.tI.value);
                const tMod = 1 + (temp - 210) * 0.005;
                const eff = (base * this.matMod * tMod).toFixed(2);
                navigator.clipboard.writeText(eff);
                const btn = document.getElementById('copy-v')!;
                const old = btn.innerHTML;
                btn.textContent = 'VALOR COPIADO';
                setTimeout(() => btn.innerHTML = old, 1500);
            });
        }

        init() {
            this.setupInputListeners();
            this.setupAutoToggle();
            this.setupMaterialButtons();
            this.setupPresetButtons();
            this.setupResetButton();
            this.setupCopyButton();
            this.run();
        }

        run() {
            const n = parseFloat(this.nI.value);
            const l = parseFloat(this.lI.value);
            const s = parseFloat(this.sI.value);
            const lim = parseFloat(this.limI.value);
            const temp = parseInt(this.tI.value);

            if (this.isAuto) this.wI.value = (n * 1.2).toFixed(2);
            const w = parseFloat(this.wI.value);

            const tMod = 1 + (temp - 210) * 0.005;
            const effLimit = lim * this.matMod * tMod;
            const flow = w * l * s;
            const maxS = effLimit / (w * l);
            const perc = (flow / effLimit) * 100;

            this.nv.textContent = `${n.toFixed(2)} mm`;
            this.wv.textContent = `${w.toFixed(2)} mm`;
            this.lv.textContent = `${l.toFixed(2)} mm`;
            this.sv.textContent = `${Math.round(s)} mm/s`;
            this.limv.textContent = `${lim.toFixed(1)} mm³/s`;
            this.tv.textContent = `${temp} °C`;

            this.fV.textContent = flow.toFixed(2);
            this.sV.textContent = `${Math.round(maxS)} mm/s`;
            this.fiF.style.width = `${Math.min(perc, 100)}%`;

            const isOver = perc > 100;
            this.updateAlerts(isOver, perc);
            this.drawChart({ w, limit: effLimit, curL: l, curS: s, n });
        }

        updateAlerts(isOver: boolean, perc: number) {
            const status = this.stV;
            const panels = [this.fP, this.sPn, this.stPn];

            panels.forEach(p => p.classList.toggle('vf-danger-state', isOver));
            status.classList.toggle('vf-danger-text', isOver);

            if (isOver) {
                status.textContent = 'ALERTA: FALLO';
                this.fiF.style.background = '#ff4400';
            } else if (perc > 80) {
                status.textContent = 'LÍMITE CRÍTICO';
                status.style.color = '#ffcc00';
                this.fiF.style.background = '#ffcc00';
            } else {
                status.textContent = 'SEGURO';
                status.style.color = '#00ffcc';
                this.fiF.style.background = '#00ffcc';
            }
        }

        drawChart(params: { w: number; limit: number; curL: number; curS: number; n: number }) {
            const { w, limit, curL, curS, n } = params;
            const xMax = Math.max(1.0, n * 1.5);
            document.getElementById('label-x-end')!.textContent = xMax.toFixed(2);

            let d = "M 0 200";
            for (let i = 0; i <= 40; i++) {
                const h = 0.05 + (i / 40) * (xMax - 0.05);
                const mS = Math.min(limit / (w * h), 600);
                const x = (i / 40) * 400;
                const y = 200 - (mS / 600) * 200;
                d += ` L ${x} ${y}`;
            }
            d += ` L 400 200 Z`;
            this.sP.setAttribute('d', d);

            const mX = ((curL - 0.05) / (xMax - 0.05)) * 400;
            const mY = 200 - (Math.min(curS, 600) / 600) * 200;
            this.sMC.setAttribute('cx', mX.toString());
            this.sMC.setAttribute('cy', mY.toString());

            const maxSAtL = limit / (w * curL);
            this.sMC.setAttribute('stroke', curS > maxSAtL ? '#ff4400' : '#00ffcc');
            this.sP.setAttribute('fill', curS > maxSAtL ? 'rgba(255, 68, 0, 0.1)' : 'rgba(0, 212, 255, 0.1)');
        }
    }

    document.addEventListener('astro:page-load', () => {
        new AdvancedFlowAgent();
    });

    new AdvancedFlowAgent();
</script>

<style>
    .vf-root {
        --vf-bg: #f9fafb;
        --vf-card: #fff;
        --vf-border: #e5e7eb;
        --vf-primary: #f40;
        --vf-secondary: #06c;
        --vf-accent: #0c9;
        --vf-text: #111827;
        --vf-text-muted: #6b7280;
        --vf-success: #0c9;

        display: flex;
        flex-direction: column;
        gap: 0;
        padding: 0;
        max-width: 1000px;
        margin: 2rem auto;
        background: var(--vf-bg);
        border: 1px solid var(--vf-border);
        border-radius: 12px;
        overflow: hidden;
        color: var(--vf-text);
    }

    :global(.theme-dark) .vf-root {
        --vf-bg: #111112;
        --vf-card: #1a1a1b;
        --vf-border: #333335;
        --vf-primary: #f40;
        --vf-secondary: #00d4ff;
        --vf-accent: #0fc;
        --vf-text: #fff;
        --vf-text-muted: #88888b;
    }

    .vf-tool-header {
        background: var(--vf-card);
        padding: 2rem;
        border-bottom: 1px solid var(--vf-border);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .vf-tool-header h2 {
        margin: 0;
        font-size: 1.5rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .vf-main-container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0;
    }

    @media (max-width: 800px) {
        .vf-main-container {
            grid-template-columns: 1fr;
        }
    }

    .vf-sidebar {
        padding: 2rem;
        border-right: 1px solid var(--vf-border);
        background: var(--vf-bg);
    }

    :global(.theme-dark) .vf-sidebar {
        border-right-color: var(--vf-border);
    }

    .vf-content-area {
        padding: 2rem;
        background: var(--vf-card);
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .vf-subsection {
        margin-bottom: 2.5rem;
    }

    .vf-subsection-title {
        font-size: 0.75rem;
        font-weight: 800;
        color: var(--vf-text-muted);
        text-transform: uppercase;
        letter-spacing: 0.2em;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .vf-control-item {
        margin-bottom: 1.5rem;
    }

    .vf-control-label-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 0.8rem;
    }

    .vf-control-label-row label {
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--vf-text);
    }

    .vf-control-value {
        font-weight: 700;
        color: var(--vf-secondary);
        font-size: 1rem;
    }

    .vf-flat-range {
        -webkit-appearance: none;
        appearance: none;
        width: 100%;
        height: 4px;
        background: var(--vf-border);
        outline: none;
        border-radius: 2px;
    }

    .vf-flat-range::-webkit-slider-thumb {
        -webkit-appearance: none;
        width: 20px;
        height: 20px;
        background: var(--vf-text);
        border: 3px solid var(--vf-primary);
        border-radius: 0;
        cursor: pointer;
    }

    .vf-flat-range::-moz-range-thumb {
        width: 20px;
        height: 20px;
        background: var(--vf-text);
        border: 3px solid var(--vf-primary);
        border-radius: 0;
        cursor: pointer;
    }

    .vf-preset-list {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.5rem;
    }

    .vf-flat-button {
        background: var(--vf-bg);
        border: 1px solid var(--vf-border);
        color: var(--vf-text);
        padding: 0.8rem;
        font-size: 0.8rem;
        font-weight: 700;
        text-align: left;
        cursor: pointer;
        transition: all 0.1s;
    }

    .vf-flat-button:hover {
        border-color: var(--vf-text-muted);
    }

    .vf-flat-button:global(.vf-active) {
        background: var(--vf-primary);
        border-color: var(--vf-primary);
        color: white;
    }

    .vf-hero-display {
        padding: 2rem;
        background: var(--vf-bg);
        border: 1px solid var(--vf-border);
        text-align: center;
        position: relative;
        transition: all 0.2s;
    }

    .vf-hero-label {
        font-size: 0.7rem;
        font-weight: 800;
        color: var(--vf-text-muted);
        text-transform: uppercase;
        letter-spacing: 0.2em;
    }

    .vf-hero-value {
        font-size: 4rem;
        font-weight: 900;
        margin: 0.5rem 0;
        color: var(--vf-text);
    }

    .vf-hero-unit {
        font-size: 0.9rem;
        font-weight: 700;
        opacity: 0.5;
    }

    .vf-limit-indicator {
        height: 4px;
        background: var(--vf-border);
        margin-top: 1.5rem;
        overflow: hidden;
    }

    .vf-limit-fill {
        height: 100%;
        width: 0;
        background: var(--vf-accent);
        transition: width 0.3s ease;
    }

    .vf-stats-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .vf-stat-box {
        padding: 1rem;
        background: var(--vf-bg);
        border: 1px solid var(--vf-border);
        transition: all 0.2s;
    }

    .vf-stat-label-box {
        font-size: 0.65rem;
        color: var(--vf-text-muted);
        text-transform: uppercase;
        margin-bottom: 0.3rem;
    }

    .vf-stat-value-box {
        font-size: 1.2rem;
        font-weight: 800;
    }

    .vf-chart-area-flat {
        height: 200px;
        border: 1px solid var(--vf-border);
        background: var(--vf-bg);
        position: relative;
        padding: 1rem;
        transition: all 0.2s;
    }

    .vf-copy-action {
        background: var(--vf-primary);
        color: white;
        border: none;
        padding: 1.2rem;
        font-weight: 800;
        font-size: 1rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        transition: background 0.2s;
    }

    .vf-copy-action:hover {
        background: #f52;
    }

    .vf-toggle-simple {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        cursor: pointer;
        font-size: 0.75rem;
        font-weight: 700;
        color: var(--vf-text-muted);
    }

    .vf-toggle-simple:global(.vf-active) {
        color: var(--vf-secondary);
    }

    .vf-toggle-box {
