---
import { FAQSection } from '@jjlmoya/utils-shared';
import { bedThermalInertiaStabilizationCalculator } from './index';
import type { KnownLocale } from '../../types';

interface Props {
  locale?: KnownLocale;
}

const { locale = 'en' } = Astro.props;
const content = await bedThermalInertiaStabilizationCalculator.i18n[locale]?.();
---

{content && <FAQSection items={content.faq} />}
