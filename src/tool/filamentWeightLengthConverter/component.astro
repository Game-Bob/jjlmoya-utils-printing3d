---
import type { FilamentWeightLengthConverterUI } from './ui';
import { FILAMENT_MATERIALS } from './logic';
import './filament-weight-to-length-converter.css';

interface Props {
  ui: FilamentWeightLengthConverterUI;
}

const { ui } = Astro.props;

const materialLabels: Record<string, string> = {
  pla: ui.materialPlaLabel,
  petg: ui.materialPetgLabel,
  abs: ui.materialAbsLabel,
  asa: ui.materialAsaLabel,
  tpu: ui.materialTpuLabel,
  pa: ui.materialPaLabel,
  pc: ui.materialPcLabel,
  wood: ui.materialWoodLabel,
  carbon: ui.materialCarbonLabel,
  metal: ui.materialMetalLabel,
};
---

<div
  class="fwlc-root"
  data-grams-unit={ui.gramsUnit}
  data-ounces-unit={ui.ouncesUnit}
  data-meters-unit={ui.metersUnit}
  data-feet-unit={ui.feetUnit}
  data-cm3-unit={ui.cm3Unit}
  data-in3-unit={ui.in3Unit}
  data-in2-unit={ui.in2Unit}
  data-mm2-unit={ui.mm2Unit}
  data-mm-unit={ui.mmUnit}
  data-inch-unit={ui.inchUnit}
  data-density-unit={ui.densityUnit}
  data-linear-mass-metric-unit={ui.linearMassMetricUnit}
  data-linear-mass-imperial-unit={ui.linearMassImperialUnit}
  data-enough-label={ui.enoughLabel}
  data-short-label={ui.shortLabel}
  data-no-stock-label={ui.noStockLabel}
  data-surplus-label={ui.surplusLabel}
  data-missing-label={ui.missingLabel}
>
  <section class="fwlc-panel">
    <div class="fwlc-topbar">
      <span>{ui.inputsTitle}</span>
      <div class="fwlc-segment" role="group" aria-label={ui.unitSystemLabel}>
        <button type="button" data-unit-system="metric" aria-pressed="true">{ui.metricLabel}</button>
        <button type="button" data-unit-system="imperial" aria-pressed="false">{ui.imperialLabel}</button>
      </div>
    </div>

    <div class="fwlc-grid">
      <label class="fwlc-field">
        <span>{ui.materialLabel}</span>
        <select id="fwlc-material">
          {FILAMENT_MATERIALS.map((material) => <option value={material.id} data-density={material.density}>{materialLabels[material.id]}</option>)}
        </select>
      </label>
      <label class="fwlc-field">
        <span>{ui.densityLabel}</span>
        <div class="fwlc-input"><input id="fwlc-density" type="number" value="1.24" min="0.1" step="0.01" /><b>{ui.densityUnit}</b></div>
      </label>
      <label class="fwlc-field">
        <span>{ui.weightLabel}</span>
        <div class="fwlc-input"><input id="fwlc-weight" type="number" value="250" min="0" step="1" /><b data-weight-unit>{ui.gramsUnit}</b></div>
        <input class="fwlc-slider" id="fwlc-weight-slider" type="range" min="0" max="1000" step="1" value="250" aria-label={ui.weightSliderLabel} />
      </label>
      <label class="fwlc-field">
        <span>{ui.diameterLabel}</span>
        <div class="fwlc-input"><input id="fwlc-diameter" type="number" value="1.75" min="0.1" step="0.01" /><b data-diameter-unit>{ui.mmUnit}</b></div>
      </label>
      <label class="fwlc-field fwlc-wide">
        <span>{ui.stockLabel}</span>
        <div class="fwlc-input"><input id="fwlc-stock" type="number" min="0" step="1" placeholder={ui.stockPlaceholder} /><b data-weight-unit>{ui.gramsUnit}</b></div>
      </label>
    </div>
  </section>

  <section class="fwlc-readout" data-stock-state="none">
    <div class="fwlc-stage">
      <div class="fwlc-hero">
        <span>{ui.resultLengthLabel}</span>
        <strong id="fwlc-length">0.00</strong>
        <em id="fwlc-length-unit">{ui.metersUnit}</em>
      </div>
      <div class="fwlc-spool-card">
        <span>{ui.spoolStateLabel}</span>
        <div class="fwlc-spool-wrap">
          <svg class="fwlc-spool" id="fwlc-spool" viewBox="0 0 160 160" role="img" aria-label={ui.spoolStateLabel}>
            <circle class="fwlc-spool-shell" cx="80" cy="80" r="66"></circle>
            <circle class="fwlc-spool-empty" cx="80" cy="80" r="48"></circle>
            <circle class="fwlc-spool-fill" id="fwlc-spool-fill" cx="80" cy="80" r="48"></circle>
            <line class="fwlc-cut-line" id="fwlc-cut-line" x1="80" y1="25" x2="80" y2="54"></line>
            <circle class="fwlc-spool-hub" cx="80" cy="80" r="22"></circle>
            <circle class="fwlc-spool-core" cx="80" cy="80" r="9"></circle>
          </svg>
          <div class="fwlc-tooltip" id="fwlc-tooltip" role="tooltip"></div>
        </div>
        <div class="fwlc-ruler" aria-label={ui.spoolScaleLabel}>
          <i id="fwlc-ruler-fill"></i>
          <b></b><b></b><b></b><b></b><b></b>
        </div>
        <small id="fwlc-ruler-label">{ui.spoolScaleLabel}</small>
        <small class="fwlc-cut-caption" id="fwlc-cut-caption">{ui.cutLineLabel}</small>
      </div>
    </div>
    <div class="fwlc-stock">
      <b id="fwlc-stock-label">{ui.noStockLabel}</b>
      <span id="fwlc-stock-delta">-</span>
    </div>
    <div class="fwlc-kpis">
      <div><span>{ui.resultVolumeLabel}</span><b id="fwlc-volume">0</b></div>
      <div><span>{ui.resultAreaLabel}</span><b id="fwlc-area">0</b></div>
      <div><span>{ui.resultGramsMeterLabel}</span><b id="fwlc-gpm">0</b></div>
    </div>
    <div class="fwlc-formula">
      <span>{ui.formulaLabel}</span>
      <code>{ui.formulaText}</code>
    </div>
  </section>
</div>

<script src="./converter.ts"></script>

