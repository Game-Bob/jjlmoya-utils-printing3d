---
import type { ShrinkageCalculatorUI } from "./ui";

interface Props {
  ui: ShrinkageCalculatorUI;
}

const { ui } = Astro.props;
---

<div class="sc-root">
  <div class="shrinkage-calculator" data-recommendations={JSON.stringify(ui.recommendations)}>
    <div class="calculator-tabs">
      <button class="tab-button active" data-tab="presets">{ui.tabPresets}</button>
      <button class="tab-button" data-tab="calibration">{ui.tabCalibration}</button>
    </div>

    <div class="calculator-grid">
      <div class="settings-panel">
        <div id="presets-view">
          <div class="form-group">
            <label class="form-label">{ui.labelDefaultMaterial}</label>
            <div class="material-grid">
              <button class="material-choice" data-shrink="1.4" data-mat="ABS">ABS</button>
              <button class="material-choice" data-shrink="0.7" data-mat="ASA">ASA</button>
              <button class="material-choice" data-shrink="1.6" data-mat="Nylon">Nylon</button>
              <button class="material-choice" data-shrink="0.3" data-mat="PETG">PETG</button>
              <button class="material-choice" data-shrink="0.2" data-mat="PLA">PLA</button>
            </div>
          </div>

          <div class="form-group margin-top">
            <label class="form-label">
              {ui.labelEstimatedShrinkage}
              <span class="small-label">{ui.unitPercent}</span>
            </label>
            <input type="number" id="shrinkage-input-field" value="1.4" step="0.1" min="0" max="10" class="numeric-input" />
          </div>
        </div>

        <div id="calibration-view" class="hidden">
          <div class="form-group">
            <label class="form-label">{ui.labelDesignSize} <span class="small-label">{ui.unitMm}</span></label>
            <input type="number" id="design-size-field" value="100" step="0.1" class="numeric-input" />
          </div>
          <div class="form-group margin-top">
            <label class="form-label">{ui.labelRealSize} <span class="small-label">{ui.unitMm}</span></label>
            <input type="number" id="real-size-field" value="98.6" step="0.1" class="numeric-input" />
          </div>
        </div>

        <div class="form-group margin-top">
          <label class="form-label">{ui.labelAxesCompensation}</label>
          <div class="axes-row">
            <div class="axis-input-box">
              <label class="axis-label">{ui.labelAxisXY}</label>
              <input type="number" id="axis-xy-read" value="100" step="0.01" readonly class="numeric-input read-only" />
            </div>
            <div class="axis-input-box">
              <label class="axis-label">{ui.labelAxisZ}</label>
              <input type="number" id="axis-z-field" value="100.1" step="0.01" class="numeric-input" />
            </div>
          </div>
          <p class="warning-note">{ui.textZWarning}</p>
        </div>

        <div class="advice-box" id="advice-container">
          <div class="advice-header">
             <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"><path fill="currentColor" d="M11 15h2v2h-2zm0-8h2v6h-2zm1-5C6.47 2 2 6.47 2 12s4.47 10 10 10s10-4.47 10-10S17.53 2 12 2"/></svg>
             {ui.labelRecommendationTitle}
          </div>
          <p class="advice-content" id="advice-text">{ui.recommendations['ABS']}</p>
        </div>
      </div>

      <div class="display-panel">
        <div class="preview-area">
          <div class="cube-scene">
            <div class="ghost-cube">
              <div class="ghost-face f-front"></div>
              <div class="ghost-face f-back"></div>
              <div class="ghost-face f-right"></div>
              <div class="ghost-face f-left"></div>
              <div class="ghost-face f-top"></div>
              <div class="ghost-face f-bottom"></div>
            </div>
            <div class="solid-cube" id="cube-visual">
              <div class="face f-front"></div>
              <div class="face f-back"></div>
              <div class="face f-right"></div>
              <div class="face f-left"></div>
              <div class="face f-top"></div>
              <div class="face f-bottom"></div>
            </div>
          </div>
        </div>

        <div class="summary-card">
          <div class="summary-entry">
            <span class="summary-title">{ui.labelResultSlicerScale}</span>
            <span class="summary-value highlight" id="scale-percent-display">101.42%</span>
          </div>
          <div class="summary-entry border-top">
            <span class="summary-title">{ui.labelResultFactor}</span>
            <span class="summary-value" id="factor-display">1.0142</span>
          </div>
        </div>

        <button class="action-btn" id="copy-scale-btn" data-copied-text={ui.btnCopied}>
          <span class="btn-text">{ui.btnCopy}</span>
        </button>
      </div>
    </div>
  </div>
</div>


<script>
  import { calculateFromShrinkage, calculateFromCalibration } from "./logic";

  interface DOMElements {
    tabs: NodeListOf<Element>;
    presetsView: HTMLElement | null;
    calibrationView: HTMLElement | null;
    materialBtns: NodeListOf<Element>;
    shrinkInput: HTMLInputElement | null;
    designInput: HTMLInputElement | null;
    realInput: HTMLInputElement | null;
    axisXY: HTMLInputElement | null;
    axisZ: HTMLInputElement | null;
    displayScale: HTMLElement | null;
    displayFactor: HTMLElement | null;
    cube: HTMLElement | null;
    copyBtn: HTMLButtonElement | null;
    adviceText: HTMLElement | null;
  }

  interface Recommendations {
    [key: string]: string;
  }

  interface CalculationResult {
    axisZ: number;
    scalingXY: number;
    factor: number;
    shrinkagePercent: number;
    cubeScaleXY: number;
    cubeScaleZ: number;
  }

  class ShrinkageCalculator {
    private mode: string = 'presets';
    private container: HTMLElement;
    private dom: DOMElements;
    private recommendations: Recommendations;

    constructor(element: HTMLElement) {
      this.container = element;
      this.dom = {
        tabs: this.container.querySelectorAll('.tab-button'),
        presetsView: this.container.querySelector('#presets-view') as HTMLElement,
        calibrationView: this.container.querySelector('#calibration-view') as HTMLElement,
        materialBtns: this.container.querySelectorAll('.material-choice'),
        shrinkInput: this.container.querySelector('#shrinkage-input-field') as HTMLInputElement,
        designInput: this.container.querySelector('#design-size-field') as HTMLInputElement,
        realInput: this.container.querySelector('#real-size-field') as HTMLInputElement,
        axisXY: this.container.querySelector('#axis-xy-read') as HTMLInputElement,
        axisZ: this.container.querySelector('#axis-z-field') as HTMLInputElement,
        displayScale: this.container.querySelector('#scale-percent-display') as HTMLElement,
        displayFactor: this.container.querySelector('#factor-display') as HTMLElement,
        cube: this.container.querySelector('#cube-visual') as HTMLElement,
        copyBtn: this.container.querySelector('#copy-scale-btn') as HTMLButtonElement,
        adviceText: this.container.querySelector('#advice-text') as HTMLElement,
      };

      this.recommendations = JSON.parse(this.container.getAttribute('data-recommendations') || '{}');
      this.init();
    }

    init() {
      this.dom.tabs.forEach((btn: Element) => btn.addEventListener('click', (e: Event) => this.switchTab(e)));
      this.dom.materialBtns.forEach((btn: Element) => btn.addEventListener('click', (e: Event) => this.selectMaterial(e)));
      
      this.dom.shrinkInput?.addEventListener('input', () => {
        const result = calculateFromShrinkage(parseFloat(this.dom.shrinkInput.value) || 0);
        this.dom.axisZ.value = result.axisZ.toFixed(2);
        this.update();
      });

      [this.dom.designInput, this.dom.realInput, this.dom.axisZ].forEach(el => {
        el?.addEventListener('input', () => this.update());
      });

      this.dom.copyBtn?.addEventListener('click', () => this.copyResult());
      this.update();
    }

    switchTab(e: Event) {
      const btn = e.currentTarget as HTMLButtonElement;
      this.mode = btn.dataset.tab || 'presets';
      this.dom.tabs.forEach((t: Element) => t.classList.toggle('active', t === btn));
      this.dom.presetsView?.classList.toggle('hidden', this.mode !== 'presets');
      this.dom.calibrationView?.classList.toggle('hidden', this.mode !== 'calibration');
      this.update();
    }

    selectMaterial(e: Event) {
      const btn = e.currentTarget as HTMLButtonElement;
      this.dom.materialBtns.forEach((b: Element) => b.classList.toggle('active', b === btn));
      const val = btn.dataset.shrink;
      const mat = btn.dataset.mat;
      if (val) {
        this.dom.shrinkInput.value = val;
        const result = calculateFromShrinkage(parseFloat(val));
        this.dom.axisZ.value = result.axisZ.toFixed(2);
      }
      if (mat && this.dom.adviceText) {
        this.dom.adviceText.textContent = this.recommendations[mat] || "";
      }
      this.update();
    }

    update() {
      const manualZ = parseFloat(this.dom.axisZ.value) || 100;
      let result;
      if (this.mode === 'presets') {
        result = calculateFromShrinkage(parseFloat(this.dom.shrinkInput.value) || 0, manualZ);
      } else {
        result = calculateFromCalibration(
          parseFloat(this.dom.designInput.value) || 0,
          parseFloat(this.dom.realInput.value) || 0,
          manualZ
        );
        this.dom.shrinkInput.value = result.shrinkagePercent.toFixed(2);
      }
      this.render(result);
    }

    render(res: CalculationResult) {
      if (this.dom.axisXY) this.dom.axisXY.value = res.scalingXY.toFixed(2);
      if (this.dom.displayScale) this.dom.displayScale.textContent = `${res.scalingXY.toFixed(2)}%`;
      if (this.dom.displayFactor) this.dom.displayFactor.textContent = res.factor.toFixed(4);
      if (this.dom.cube) {
        this.dom.cube.style.transform = `scale3d(${res.cubeScaleXY}, ${res.cubeScaleZ}, ${res.cubeScaleXY})`;
      }
    }

    copyResult() {
      const text = this.dom.displayScale?.textContent || "";
      navigator.clipboard.writeText(text).then(() => {
        const textNode = this.dom.copyBtn.querySelector('.btn-text');
        const original = textNode?.textContent || "";
        if (textNode) textNode.textContent = this.dom.copyBtn.dataset.copiedText || "Copied!";
        setTimeout(() => { if (textNode) textNode.textContent = original; }, 2000);
      });
    }
  }

  const start = () => {
    document.querySelectorAll('.shrinkage-calculator').forEach(el => new ShrinkageCalculator(el as HTMLElement));
  };
  document.addEventListener('astro:page-load', start);
  start();
</script>
