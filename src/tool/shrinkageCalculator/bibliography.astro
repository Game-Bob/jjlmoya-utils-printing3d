---
import { Bibliography as SharedBibliography } from '@jjlmoya/utils-shared';
import { SHRINKAGE_CALCULATOR_TOOL } from './index';
import type { KnownLocale } from '../../types';

interface Props {
  locale?: KnownLocale;
}

const { locale = 'es' } = Astro.props;
const content = await SHRINKAGE_CALCULATOR_TOOL.entry.i18n[locale as keyof typeof SHRINKAGE_CALCULATOR_TOOL.entry.i18n]?.();
---

{content && <SharedBibliography links={content.bibliography} />}
